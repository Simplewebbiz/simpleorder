APP_NAME="SimpleOrder"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://simpleorder.com
CENTRAL_DOMAINS=simpleorder.com,www.simpleorder.com

# Central database (platform-level: tenants, plans, subscriptions)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=simpleorder_central
DB_USERNAME=root
DB_PASSWORD=

# Tenant database prefix (each tenant gets: simpleorder_tenant_{id})
TENANCY_DB_PREFIX=simpleorder_tenant_
TENANCY_DB_TEMPLATE_CONNECTION=tenant

# Queue (sync is simplest on cPanel; switch to database only after creating central queue tables and running a worker)
QUEUE_CONNECTION=sync

# Broadcasting (Laravel Reverb for real-time order status)
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="0.0.0.0"
REVERB_PORT=8080
REVERB_SCHEME=https
VITE_REVERB_APP_KEY=${REVERB_APP_KEY}
VITE_REVERB_HOST=simpleorder.com
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=https

# Stripe - platform account (for tenant subscriptions via Stripe Billing)
STRIPE_KEY=pk_live_
STRIPE_SECRET=sk_live_
STRIPE_WEBHOOK_SECRET=whsec_

# Stripe Connect - platform fee per order (e.g. 0.02 = 2%)
STRIPE_PLATFORM_FEE=0.02
STRIPE_CLIENT_ID=

# Resend - all transactional email
RESEND_API_KEY=re_
MAIL_FROM_ADDRESS=noreply@simpleorder.com
MAIL_FROM_NAME="SimpleOrder"

# Google Maps - delivery address geocoding
GOOGLE_MAPS_API_KEY=

# Twilio - SMS notifications on order status changes
TWILIO_ENABLED=false
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=+15551234567

# Filesystem
FILESYSTEM_DISK=local

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=.simpleorder.com

CACHE_STORE=file
LOG_CHANNEL=stack
LOG_LEVEL=error
